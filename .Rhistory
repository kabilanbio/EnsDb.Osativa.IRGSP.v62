# Verify the database is usable
edb <- EnsDb("D:\\IARI_NEW DELHI\\Ph.D\\Research\\Work - Objective 1\\Simulation_techniques_comparison\\Rice_datasets\\GRN_construction\\New_Annotation_Package\\Oryza_sativa.IRGSP-1.0.62.sqlite")
# Check that genes are present
genes <- genes(edb)
head(genes)
# 1) Read chromosome sizes from the GFF again and format correctly
gff <- rtracklayer::readGFF(
"D:\\IARI_NEW DELHI\\Ph.D\\Research\\Work - Objective 1\\Simulation_techniques_comparison\\Rice_datasets\\GRN_construction\\Annotation_package_R\\Oryza_sativa.IRGSP-1.0.62.gff3"
)
chrom_info <- as.data.frame(gff[gff$type == "chromosome", c("seqid", "end")])
colnames(chrom_info) <- c("seq_name", "seq_length")
# All chromosomes here are linear (is_circular = 0), except possibly organelle ones.
# IRGSP-1.0 has only nuclear chromosomes; they are linear.
chrom_info$is_circular <- 0L   # 0 = linear, 1 = circular
# 2) Connect to the database and fix the chromosome table
con <- dbConnect(SQLite(), "D:/IARI_NEW DELHI/Ph.D/Research/Work - Objective 1/Simulation_techniques_comparison/Results/Rice_datasets/GRN_construction/Annotation_package_R/Oryza_sativa.IRGSP-1.0.62.sqlite")
# 2) Connect to the database and fix the chromosome table
con <- dbConnect(SQLite(), "D:\\IARI_NEW DELHI\\Ph.D\\Research\\Work - Objective 1\\Simulation_techniques_comparison\\Rice_datasets\\GRN_construction\\New_Annotation_Package\\Oryza_sativa.IRGSP-1.0.62.sqlite")
# Drop the current (wrong) chromosome table
dbExecute(con, "DROP TABLE IF EXISTS chromosome")
# Recreate the table with the exact schema EnsDb expects
dbExecute(con, "CREATE TABLE chromosome (
seq_name TEXT NOT NULL,
seq_length INTEGER NOT NULL,
is_circular INTEGER NOT NULL
)")
# Write the corrected data
dbWriteTable(con, "chromosome", chrom_info, append = TRUE, row.names = FALSE)
dbDisconnect(con)
# 3) Verify
edb <- EnsDb("D:\\IARI_NEW DELHI\\Ph.D\\Research\\Work - Objective 1\\Simulation_techniques_comparison\\Rice_datasets\\GRN_construction\\New_Annotation_Package\\Oryza_sativa.IRGSP-1.0.62.sqlite"))
# 3) Verify
edb <- EnsDb("D:\\IARI_NEW DELHI\\Ph.D\\Research\\Work - Objective 1\\Simulation_techniques_comparison\\Rice_datasets\\GRN_construction\\New_Annotation_Package\\Oryza_sativa.IRGSP-1.0.62.sqlite")
seqinfo(edb)
gene_gr <- genes(edb)
seqlevelsStyle(gene_gr) <- "UCSC"   # this should add 'chr' prefix, but we must verify
seqinfo(gene_gr)
#Keep only the 12 rice chromosomes
gene_gr <- keepStandardChromosomes(gene_gr, pruning.mode = "coarse")
genome.info <- list(
gene_gr = gene_gr,
promoter_region = "D:\\IARI_NEW DELHI\\Ph.D\\Research\\Work - Objective 1\\Simulation_techniques_comparison\\Rice_datasets\\GRN_construction\\Annotation_package_R\\rice_promoter_regions.txt",
colour = NULL
)
##  Load the MSU GFF3 and extract descriptions
msu_gff   <- readGFF("D:\\IARI_NEW DELHI\\Ph.D\\Research\\Work - Objective 1\\Simulation_techniques_comparison\\Rice_datasets\\GRN_construction\\Annotation_package_R\\all.gff3")                   # you already have this
msu_genes <- msu_gff[msu_gff$type == "gene", ]
msu_id    <- gsub("gene:", "", msu_genes$ID)        # MSU locus, e.g. LOC_Os01g01010
msu_note  <- msu_genes$Note                          # functional description
# Build MSU -> Description lookup (keep first occurrence)
msu_desc <- data.frame(MSU = msu_id, Description = msu_note, stringsAsFactors = FALSE)
msu_desc <- msu_desc[!duplicated(msu_desc$MSU), ]
# Fix: Extract Description.value if Note is a list or data.frame
# If msu_note is a list or has nested structures, extract the first value
if (is.list(msu_note) || is.data.frame(msu_note)) {
msu_desc$Description <- sapply(msu_note, function(x) if (length(x) > 0) x[1] else NA)
}
## Map RAP‑DB → MSU → Description
# Load RAP‑MSU mapping (the one you already have)
rap_msu <- read.table("D:\\IARI_NEW DELHI\\Ph.D\\Research\\Work - Objective 1\\Simulation_techniques_comparison\\Rice_datasets\GRN_construction\\Annotation_package_R\\RAP-MSU_2026-02-05.txt",
## Map RAP‑DB → MSU → Description
# Load RAP‑MSU mapping (the one you already have)
rap_msu <- read.table("D:\\IARI_NEW DELHI\\Ph.D\\Research\\Work - Objective 1\\Simulation_techniques_comparison\\Rice_datasets\\GRN_construction\\Annotation_package_R\\RAP-MSU_2026-02-05.txt",
header = TRUE, sep = "\t", stringsAsFactors = FALSE)
colnames(rap_msu)[1:2] <- c("RAP", "MSU")
# Clean the MSU column in rap_msu
rap_msu$MSU <- gsub("\\.[0-9]+", "", rap_msu$MSU)  # Remove .1, .2, etc.
rap_msu$MSU <- gsub(",None|None,", "", rap_msu$MSU) # Remove None
rap_msu$MSU <- gsub(",,", ",", rap_msu$MSU)         # Remove double commas
rap_msu$MSU <- trimws(rap_msu$MSU)                 # Trim whitespace
# For unique values in each row (no duplicates)
rap_msu$MSU <- sapply(
strsplit(rap_msu$MSU, ","),
function(x) paste(unique(na.omit(x)), collapse = ",")
)
# Rename the description column if needed
if ("Description.value" %in% colnames(msu_desc)) {
colnames(msu_desc)[colnames(msu_desc) == "Description.value"] <- "Description"
}
# Merge to get RAP -> Description
rap_desc <- merge(rap_msu, msu_desc, by = "MSU")[, c("RAP", "MSU", "Description")]
rap_desc <- rap_desc[!duplicated(rap_desc$RAP), ]
head(rap_desc)
