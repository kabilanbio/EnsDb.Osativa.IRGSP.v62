outfile = "D:\\IARI_NEW DELHI\\Ph.D\\Research\\Work - Objective 1\\Simulation_techniques_comparison\\Rice_datasets\\GRN_construction\\New_Annotation_Package\\Oryza_sativa.IRGSP-1.0.62.sqlite",
